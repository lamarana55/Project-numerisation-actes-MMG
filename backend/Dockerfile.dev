# ============================================================
#  Backend Spring Boot — Dockerfile DÉVELOPPEMENT
#  Hot-reload via Maven spring-boot:run + DevTools
# ============================================================

FROM maven:3.9-eclipse-temurin-21

WORKDIR /app

# Copier d'abord le pom.xml seul pour profiter du cache Docker
# (les dépendances ne sont retéléchargées que si pom.xml change)
COPY pom.xml .
# BuildKit cache mount : le dossier .m2 persiste entre les builds → pas de re-téléchargement
RUN --mount=type=cache,target=/root/.m2 \
    mvn dependency:go-offline -B \
      -Dmaven.wagon.http.retryHandler.count=5 \
      -Dmaven.wagon.httpconnectionManager.ttlSeconds=120

# Copier le code source
COPY src ./src

# Exposer le port de l'application + port LiveReload DevTools
EXPOSE 8091

# Lancer Spring Boot en mode dev avec recompilation automatique
# spring-boot:run surveille les fichiers et redémarre l'application
CMD ["mvn", "spring-boot:run", \
     "-Dspring-boot.run.jvmArguments=-Dspring.devtools.restart.enabled=true"]
