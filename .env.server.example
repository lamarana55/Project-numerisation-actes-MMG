# ============================================================
#  MODÈLE de variables d'environnement — Serveur de production
#  Copier en `.env` sur le serveur (/opt/pn-ravec/.env) et renseigner.
#  ⚠️ NE JAMAIS committer le `.env` réel. Ce fichier .example ne contient
#     QUE des valeurs factices.
# ============================================================

# ── Base de données (conteneur interne) ──────────────────────────────────
DATABASE=ravec_db
DATABASE_USER=ravec_user
DATABASE_PASSWORD=__A_DEFINIR__
DDL_AUTO=validate

# ── Backend ──────────────────────────────────────────────────────────────
SERVER_PORT=8091
FRONT_URL=https://validation.ravec.gov.gn:8050
# Secret JWT (Base64, 64+ caractères) — générer : openssl rand -base64 64
JWT_SECURITY=__A_DEFINIR__
DEFAULT_USER_PASSWORD=__A_DEFINIR__

# ── Email SMTP ───────────────────────────────────────────────────────────
SPRING_MAIL_USERNAME=admin@ravec.gov.gn
SPRING_MAIL_PASSWORD=__A_DEFINIR__

# ── NimbaSMS (OTP / SMS) ─────────────────────────────────────────────────
NIMBASMS_SERVICE_ID=__A_DEFINIR__
NIMBASMS_SECRET_TOKEN=__A_DEFINIR__
NIMBASMS_SENDER_NAME=PN RAVEC

# ── Images Docker (injectées par le pipeline ; latest par défaut) ────────
BACKEND_IMAGE=ghcr.io/lamarana55/ravec-backend:latest
FRONTEND_IMAGE=ghcr.io/lamarana55/ravec-frontend:latest

# ── PgAdmin (profil "tools", optionnel) ──────────────────────────────────
PGADMIN_EMAIL=admin@ravec.gov.gn
PGADMIN_PASSWORD=__A_DEFINIR__

# ── Monitoring (profil observabilité, optionnel) ─────────────────────────
GRAFANA_PASSWORD=__A_DEFINIR__

# ── Sauvegardes ──────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
